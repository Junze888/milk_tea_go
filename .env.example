APP_ENV=dev
HTTP_ADDR=:8080

POSTGRES_DSN=postgres://milktea:milktea@127.0.0.1:5432/milktea?sslmode=disable
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# 生产环境务必改为高强度随机串（建议 32+ 字节）
JWT_ACCESS_SECRET=change-me-access-secret-32bytes!!
JWT_REFRESH_SECRET=change-me-refresh-secret-32bytes!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# 单机高并发：按 CPU/内存与 PostgreSQL max_connections 压测调整
PG_MAX_CONNS=120
PG_MIN_CONNS=10
PG_MAX_CONN_LIFETIME=1h
PG_MAX_CONN_IDLE=15m

REDIS_POOL_SIZE=200
REDIS_MIN_IDLE=20

# 每 IP 令牌桶（可按网关前置策略调大）
RATE_LIMIT_RPS=200
RATE_LIMIT_BURST=400

CACHE_TEA_DETAIL_TTL=5m
CACHE_TEA_LIST_TTL=2m
CACHE_LEADERBOARD_TTL=1m

# 迁移目录（Docker 镜像内默认 /app/migrations）
MIGRATIONS_DIR=migrations
